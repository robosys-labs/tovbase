# Tovbase / Trustgate environment configuration
# Copy to .env and adjust values for your environment.

# Core
ENV=development
API_HOST=0.0.0.0
API_PORT=8001

# Database (PostgreSQL)
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/tovbase

# Redis (cache + Celery broker)
REDIS_URL=redis://localhost:6379/0

# Qdrant (vector similarity search)
QDRANT_URL=http://localhost:6333
QDRANT_COLLECTION=identity_vectors

# CORS — comma-separated allowed origins (production)
CORS_ORIGINS=http://localhost:3002,http://localhost:3000

# Security
SECRET_KEY=changeme-generate-a-random-string
ADMIN_API_KEY=changeme

# Docker / Gunicorn (production only)
# WEB_CONCURRENCY=2
# GUNICORN_TIMEOUT=120

# Next.js frontend
API_URL=http://localhost:8001/v1
