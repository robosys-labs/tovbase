# =============================================================================
# Tovbase — Production Environment Variables
# =============================================================================
# Copy to .env for production deployment. All values below are REQUIRED unless
# marked (optional). Defaults shown are examples — replace with real values.
# =============================================================================

# ---------------------------------------------------------------------------
# Core
# ---------------------------------------------------------------------------
ENV=production

# ---------------------------------------------------------------------------
# Database — PostgreSQL 16 connection string
# ---------------------------------------------------------------------------
# Format: postgresql://<user>:<password>@<host>:<port>/<dbname>
DATABASE_URL=postgresql://tovbase:CHANGE_ME@db:5432/tovbase

# ---------------------------------------------------------------------------
# Redis — cache layer + Celery broker
# ---------------------------------------------------------------------------
# Format: redis://[:password]@<host>:<port>/<db>
REDIS_URL=redis://redis:6379/0

# ---------------------------------------------------------------------------
# Qdrant — vector similarity search (HNSW, 32-dim, cosine)
# ---------------------------------------------------------------------------
QDRANT_URL=http://qdrant:6333
QDRANT_COLLECTION=identity_vectors

# ---------------------------------------------------------------------------
# API / Frontend connection
# ---------------------------------------------------------------------------
# The public URL of the FastAPI backend (used by Next.js rewrites)
API_URL=https://api.example.com/v1

# ---------------------------------------------------------------------------
# Security
# ---------------------------------------------------------------------------
# Admin API key for /v1/admin/* endpoints — generate a strong random value
ADMIN_API_KEY=CHANGE_ME

# Comma-separated list of allowed CORS origins
# Include your production frontend URL and chrome-extension origins
CORS_ORIGINS=https://app.example.com,chrome-extension://*

# ---------------------------------------------------------------------------
# Scoring weights (optional — defaults are 1.0 for all)
# ---------------------------------------------------------------------------
# SCORE_EXISTENCE_WEIGHT=1.0
# SCORE_CONSISTENCY_WEIGHT=1.0
# SCORE_ENGAGEMENT_WEIGHT=1.0
# SCORE_CROSS_PLATFORM_WEIGHT=1.0
# SCORE_MATURITY_WEIGHT=1.0

# ---------------------------------------------------------------------------
# Similarity thresholds (optional — defaults shown)
# ---------------------------------------------------------------------------
# SIMILARITY_AUTO_LINK_THRESHOLD=0.75
# SIMILARITY_REVIEW_THRESHOLD=0.55

# ---------------------------------------------------------------------------
# Cache TTLs in seconds (optional — defaults shown)
# ---------------------------------------------------------------------------
# CACHE_SCORE_TTL=3600       # 1 hour
# CACHE_PROFILE_TTL=86400    # 24 hours
# CACHE_RESOLVE_TTL=86400    # 24 hours

# ---------------------------------------------------------------------------
# Company scoring weights (optional — defaults are 1.0 for all)
# ---------------------------------------------------------------------------
# COMPANY_FOUNDER_WEIGHT=1.0
# COMPANY_PRODUCT_WEIGHT=1.0
# COMPANY_COMMUNITY_WEIGHT=1.0
# COMPANY_PRESENCE_WEIGHT=1.0
# COMPANY_EXECUTION_WEIGHT=1.0
# COMPANY_CONSISTENCY_WEIGHT=1.0

# ---------------------------------------------------------------------------
# Crawling (optional)
# ---------------------------------------------------------------------------
# Lightpanda headless browser URL — leave empty to disable
# LIGHTPANDA_URL=http://lightpanda:9222
# BROWSER_PROFILE_DIR=data/browser_profiles
